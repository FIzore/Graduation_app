{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "齐鲁工大二手平台"
			}
		},
		{
			"path": "pages/item/detail",
			"style": {
				"navigationBarTitleText": "物品详情",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/auth/login",
			"style": {
				"navigationBarTitleText": "登录",
				"navigationBarBackgroundColor": "#FFFFFF",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/item/post",
			"style": {
				"navigationBarTitleText": "发布闲置",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/message/message",
			"style": {
				"navigationBarTitleText": "消息",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/profile/profile",
			"style": {
				"navigationBarTitleText": "我的",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/profile/published",
			"style": {
				"navigationBarTitleText": "我的发布",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/profile/appointments",
			"style": {
				"navigationBarTitleText": "我的预约",
				"navigationStyle": "custom"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "齐鲁工大二手平台",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"tabBar": {
		"color": "#999",
		"selectedColor": "#07c160",
		"borderStyle": "white",
		"backgroundColor": "#fff",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "首页"
			},
			{
				"pagePath": "pages/item/post",
				"text": "发布"
			},
			{
				"pagePath": "pages/message/message",
				"text": "消息"
			},
			{
				"pagePath": "pages/profile/profile",
				"text": "我的"
			}
		]
	},
	"uniIdRouter": {}
}
